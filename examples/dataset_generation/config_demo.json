{
  "output_dir": "/pscratch/sd/i/ilgar/georules_dataset_demo",
  "seed": 42,
  "shard_size": 10000,
  "grid": {
    "nx": 64, "ny": 64, "nz": 32,
    "x_len": 5000.0, "y_len": 5000.0, "z_len": 30.0,
    "top_depth": 2000.0, "dip": 0.0, "kzkx": 0.1
  },
  "layers": {
    "lobe": {
      "count": 2,
      "sampling": "sobol",
      "params": {
        "poro_ave":     {"range": [0.15, 0.35]},
        "perm_ave":     {"range": [0, 4]},
        "poro_std":     {"range": [0.01, 0.05]},
        "perm_std":     {"range": [0.1, 1.5]},
        "ntg":          {"range": [0.2, 0.8]},
        "dhmin":        {"range": [2, 5],     "type": "int"},
        "dhmax":        {"range": [6, 10],    "type": "int"},
        "rmin":         {"range": [20, 45]},
        "rmax":         {"range": [50, 80]},
        "asp":          {"range": [1.0, 2.5]},
        "bouma_factor": {"range": [0, 2]},
        "m":            {"value": 100},
        "upthinning":   {"choices": [true, false]}
      }
    },
    "gaussian": {
      "count": 2,
      "sampling": "sobol",
      "params": {
        "poro_ave":       {"range": [0.15, 0.35]},
        "perm_ave":       {"range": [0, 4]},
        "poro_std":       {"range": [0.01, 0.05]},
        "perm_std":       {"range": [0.1, 1.5]},
        "ntg":            {"range": [0.2, 0.8]},
        "nugget":         {"range": [0.01, 0.15]},
        "poro_perm_corr": {"range": [0.3, 0.9]}
      }
    },
    "meandering": {
      "count": 2,
      "sampling": "lhs",
      "params": {
        "channel_width":            {"range": [50, 300]},
        "n_channels":               {"range": [4, 20], "type": "int"},
        "depth_width_ratio":        {"range": [0.2, 0.6]},
        "slope":                    {"range": [0.002, 0.02], "scale": "log"},
        "meander_scale":            {"range": [0.8, 2.0]},
        "migration_distance_ratio": {"range": [0.5, 2.0]},
        "nlevel":                   {"range": [4, 10], "type": "int"},
        "azimuth":                  {"range": [0, 360]}
      }
    },
    "braided": {
      "count": 2,
      "sampling": "sobol",
      "params": {
        "braidplain_width":         {"range": [500, 3000]},
        "n_channels":               {"range": [15, 35], "type": "int"},
        "slope":                    {"range": [0.005, 0.03], "scale": "log"},
        "meander_scale":            {"range": [0.5, 1.5]},
        "migration_distance_ratio": {"range": [0.1, 0.6]},
        "azimuth":                  {"range": [0, 360]}
      }
    },
    "delta": {
      "count": 2,
      "sampling": "sobol",
      "params": {
        "feeder_width":          {"range": [30, 120]},
        "n_generations":         {"range": [4, 10], "type": "int"},
        "fan_angle_deg":         {"range": [60, 130]},
        "bifurcation_depth":     {"range": [3, 6], "type": "int"},
        "fan_asymmetry":         {"range": [-0.5, 0.5]},
        "azimuth":               {"range": [0, 360]},
        "apex_x_fraction":       {"range": [0.1, 0.4]},
        "progradation_fraction": {"range": [0.0, 0.5]},
        "trunk_length_factor":   {"range": [3.0, 8.0]}
      }
    }
  }
}
